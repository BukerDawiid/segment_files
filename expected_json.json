///////// HOME

// GA4 NAME search_Started
// SEGMENT NAME Search Started
// Description: Tracks the Started of a flight search using the selected criteria.
{
  "type": "track",
  "anonymousId": "MandatorySegment",
  "event": "Search Started",
  "properties": {
    "hashed_email": "datalayerSourceTBD",
    "passenger_adult_count": "adult_count",
    "passenger_child_count": "child_count",
    "passenger_baby_count": "baby_count",
    "pnr_total_number_of_passengers": "pax_number",
    "flight_type": "flight_type",
    "flight_route": "departure_flight",
    "flight_route_return": "return_flight",
    "route_origin_departure": "departureoriginstationiata",
    "route_arrival_departure": "departurearrivalstationiata",
    "route_origin_return": "returnoriginstationiata",
    "route_arrival_return": "returnarrivalstationiata",
    "departure_date": "departuredate",
    "return_date": "returndate",
    "trip_duration_days": "trip_duration",
    "days_in_advance": "days_in_advance",
    "pnr_countries_visited": "country_route",
    "product_id": "item_id",
    "extra_seat": "extra_seat",
    "session_id": "ga_session_id",
    "session_number": "ga_session_number"
  },
  "context": {
    "page": {
      "path": "page_path",
      "url": "page_location",
      "title": "page_title",
      "referrer": "page_referrer"
    },
    "campaign": {
      "source": "utm_source",
      "medium": "utm_medium",
      "name": "utm_campaign",
      "term": "utm_term",
      "content": "utm_content"
    },
    "gclid": "gclid",
    "dclid": "dclid",
    "gbraid": "gbraid",
    "wbraid": "wbraid",
    "fbclid": "fbclid",
    "ttclid": "ttclid",
    "msclkid": "msclkid",
    "epik": "epik",
    "li_fat_id": "li_fat_id",
    "twclid": "twclid"
  }
}

